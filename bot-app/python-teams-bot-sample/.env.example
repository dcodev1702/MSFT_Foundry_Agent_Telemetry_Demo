# ════════════════════════════════════════════════════════════════
# M365 Agents SDK Configuration
# ════════════════════════════════════════════════════════════════

# Bot App Registration (from Entra ID)
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=<bot-app-registration-client-id>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=<bot-secret-or-leave-empty-for-managed-identity>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=<entra-tenant-id>

# Server
PORT=3978

# Deploy script path (absolute path to deploy-foundry-env.ps1)
# Defaults to ../../deployment/deploy-foundry-env.ps1 relative to this directory
# DEPLOY_SCRIPT_PATH=/path/to/deploy-foundry-env.ps1

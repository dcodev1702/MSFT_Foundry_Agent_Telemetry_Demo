# ════════════════════════════════════════════════════════════════
# Dockerfile.worker — PowerShell/Bicep worker container
#
# Bundles: Python 3.14 + PowerShell 7.4 + Azure CLI + Bicep +
#          Azure Developer CLI (azd) + Az/Graph PowerShell modules
#
# Runs the BackgroundWorker standalone (no web server).
# Polls Azure Queue Storage for queued jobs, executes PowerShell,
# and sends results back via proactive messaging.
#
# Build (from repo root):
#   docker build -t zolab-worker:latest -f deployment/Dockerfile.worker .
#
# Run locally:
#   docker run --env-file bot-app/runtime/.env zolab-worker:latest
# ════════════════════════════════════════════════════════════════

FROM python:3.13-slim-bookworm AS base

ENV DEBIAN_FRONTEND=noninteractive

ARG WORKER_BUILD_UTC=unknown
ARG WORKER_BUILD_COMMIT=unknown
ARG WORKER_BUILD_SOURCE=manual

# ── System dependencies ──────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
        apt-transport-https \
        ca-certificates \
        curl \
        gnupg \
        lsb-release \
        unzip \
    && rm -rf /var/lib/apt/lists/*

# ── PowerShell 7.4 ──────────────────────────────────────────────
RUN curl -fsSL https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /usr/share/keyrings/microsoft.gpg \
    && echo "deb [arch=amd64 signed-by=/usr/share/keyrings/microsoft.gpg] https://packages.microsoft.com/repos/microsoft-debian-bookworm-prod bookworm main" \
        > /etc/apt/sources.list.d/microsoft.list \
    && apt-get update && apt-get install -y --no-install-recommends powershell \
    && rm -rf /var/lib/apt/lists/*

# ── Azure CLI (supported Debian package) ────────────────────────
RUN mkdir -p /etc/apt/keyrings \
    && curl -sLS https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /etc/apt/keyrings/microsoft.gpg \
    && chmod go+r /etc/apt/keyrings/microsoft.gpg \
    && printf '%s\n' \
        'Types: deb' \
        'URIs: https://packages.microsoft.com/repos/azure-cli/' \
        'Suites: bookworm' \
        'Components: main' \
        'Architectures: amd64' \
        'Signed-By: /etc/apt/keyrings/microsoft.gpg' > /etc/apt/sources.list.d/azure-cli.sources \
    && apt-get update \
    && apt-get install -y --no-install-recommends azure-cli \
    && rm -rf /var/lib/apt/lists/*

# ── Bicep CLI (extension of Azure CLI) ───────────────────────────
RUN az bicep install

# ── Azure Developer CLI (azd) ───────────────────────────────────
RUN curl -fsSL https://aka.ms/install-azd.sh | bash

# ── PowerShell modules (Az + Microsoft.Graph) ───────────────────
RUN pwsh -NoProfile -Command " \
    Set-PSRepository -Name PSGallery -InstallationPolicy Trusted; \
    Install-Module -Name Az.Accounts          -Scope AllUsers -Force; \
    Install-Module -Name Az.Resources         -Scope AllUsers -Force; \
    Install-Module -Name Az.Storage           -Scope AllUsers -Force; \
    Install-Module -Name Az.CognitiveServices -Scope AllUsers -Force; \
    Install-Module -Name Microsoft.Graph.Authentication -Scope AllUsers -Force; \
    Install-Module -Name Microsoft.Graph.Groups         -Scope AllUsers -Force; \
    Install-Module -Name Microsoft.Graph.Users          -Scope AllUsers -Force; \
    Update-AzConfig -CheckForUpgrade \$false -Scope CurrentUser -AppliesTo Az -Confirm:\$false | Out-Null; \
    "

# ── Application layout ──────────────────────────────────────────
#
#   /app/
#     bot-app/runtime/                   ← runtime root
#       src/                            ← worker code (workdir)
#     deployment/                        ← PowerShell scripts + Bicep
#
# Matches app.py / worker_standalone.py path resolution:
#   BASE_PATH.parent.parent.parent / "deployment" / "deploy-foundry-env.ps1"
# ─────────────────────────────────────────────────────────────────

WORKDIR /app

RUN printf '{\n  "build_utc": "%s",\n  "build_commit": "%s",\n  "build_source": "%s"\n}\n' \
    "$WORKER_BUILD_UTC" "$WORKER_BUILD_COMMIT" "$WORKER_BUILD_SOURCE" > /app/worker-build-info.json

# Copy deployment scripts + Bicep templates
COPY deployment/ /app/deployment/

# Copy bot application code (worker + proactive + models + store)
COPY bot-app/runtime/ /app/bot-app/runtime/

# ── Python dependencies ──────────────────────────────────────────
RUN python -m pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir --upgrade -r /app/bot-app/runtime/requirements.txt

# ── Startup ──────────────────────────────────────────────────────
WORKDIR /app/bot-app/runtime/src

CMD ["python", "worker_standalone.py"]
